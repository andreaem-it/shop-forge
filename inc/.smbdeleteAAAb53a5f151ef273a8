function bncom_render_account_dashboard(): void {
    if ( ! function_exists( 'wc_get_orders' ) || ! is_user_logged_in() ) {
        return;
    }

    $user_id      = get_current_user_id();
    $user         = wp_get_current_user();
    $display_name = $user->display_name ?: $user->user_login;

    $recent_orders = wc_get_orders( [
        'customer_id' => $user_id,
        'limit'       => 5,
        'orderby'     => 'date',
        'order'       => 'DESC',
        'return'      => 'objects',
    ] );

    $total_orders = wc_get_orders( [
        'customer_id' => $user_id,
        'limit'       => -1,
        'return'      => 'ids',
    ] );

    $processing_orders = wc_get_orders( [
        'customer_id' => $user_id,
        'status'      => [ 'processing', 'on-hold' ],
        'limit'       => -1,
        'return'      => 'ids',
    ] );

    $completed_orders = wc_get_orders( [
        'customer_id' => $user_id,
        'status'      => [ 'completed' ],
        'limit'       => -1,
        'return'      => 'ids',
    ] );

    $billing_address  = wc_get_account_formatted_address( 'billing' );
    $shipping_address = wc_get_account_formatted_address( 'shipping' );

    $stats = [
        [
            'icon'      => 'fa-solid fa-bag-shopping',
            'label'     => 'Ordini totali',
            'value'     => count( $total_orders ),
            'link_text' => 'Visualizza ordini',
            'url'       => wc_get_account_endpoint_url( 'orders' ),
        ],
        [
            'icon'      => 'fa-solid fa-clock',
            'label'     => 'In lavorazione',
            'value'     => count( $processing_orders ),
            'link_text' => 'Controlla stato',
            'url'       => wc_get_account_endpoint_url( 'orders' ),
        ],
        [
            'icon'      => 'fa-solid fa-truck',
            'label'     => 'Consegnati',
            'value'     => count( $completed_orders ),
            'link_text' => 'Storico acquisti',
            'url'       => wc_get_account_endpoint_url( 'orders' ),
        ],
        [
            'icon'      => 'fa-solid fa-file-invoice',
            'label'     => 'Preventivi',
            'value'     => 0,
            'link_text' => 'Vai ai preventivi',
            'url'       => wc_get_account_endpoint_url( 'bncom-quotes' ),
        ],
    ];
    ?>
