defined( 'ABSPATH' ) || exit;


// =============================================================================
// MENU ADMIN
// =============================================================================

add_action( 'admin_menu', function () {
	add_submenu_page(
		'woocommerce',
		'Andrea Emili — Moduli',
		'Andrea Emili Moduli',
		'manage_woocommerce',
		'shopforge-modules',
		'shopforge_settings_page_render'
	);
} );


// =============================================================================
// SALVATAGGIO
// =============================================================================

add_action( 'admin_post_shopforge_save_modules', function () {
	if ( ! current_user_can( 'manage_woocommerce' )
	     || ! check_admin_referer( 'shopforge_save_modules' ) ) {
		wp_die( 'Accesso non autorizzato.' );
	}

	$all_ids = array_keys( shopforge_modules_registry() );
	$enabled = [];

	foreach ( $all_ids as $id ) {
		if ( ! empty( $_POST[ 'module_' . $id ] ) ) {
			$enabled[] = $id;
		}
	}

	$old = shopforge_get_enabled_modules();
	update_option( 'shopforge_modules_enabled', $enabled );

	// Se la lista è cambiata, svuota le rewrite rules
	if ( array_diff( $old, $enabled ) || array_diff( $enabled, $old ) ) {
		flush_rewrite_rules();
	}

	wp_redirect( admin_url( 'admin.php?page=shopforge-modules&updated=1' ) );
	exit;
} );


// =============================================================================
// RENDER PAGINA
// =============================================================================

