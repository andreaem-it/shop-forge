// =============================================================================
// HELPER: stato moduli
// =============================================================================

/**
 * Restituisce gli ID dei moduli attivi.
 * Default: tutti attivi (primo avvio senza impostazioni salvate).
 */
function bncom_get_enabled_modules(): array {
	$all     = array_keys( bncom_modules_registry() );
	$saved   = get_option( 'bncom_modules_enabled', null );
	return ( $saved === null ) ? $all : (array) $saved;
}

function bncom_is_module_active( string $id ): bool {
	return in_array( $id, bncom_get_enabled_modules(), true );
}


// =============================================================================
// LOADER: carica i file dei moduli attivi
// =============================================================================

function bncom_load_modules(): void {
	foreach ( bncom_modules_registry() as $id => $module ) {
		if ( bncom_is_module_active( $id ) ) {
			$file = BNCOM_SA_DIR . 'inc/modules/' . $module['file'];
			if ( file_exists( $file ) ) {
				require_once $file;
			}
		}
	}
}


// =============================================================================
// REWRITE ENDPOINTS: sempre registrati per stabilità degli URL
// (la visibilità è controllata dal menu filter)
// =============================================================================

add_action( 'init', function () {
	foreach ( bncom_modules_registry() as $module ) {
		if ( ! empty( $module['endpoint'] ) ) {
			add_rewrite_endpoint( $module['endpoint'], EP_ROOT | EP_PAGES );
		}
	}
} );


// =============================================================================
// MENU ACCOUNT: voci dinamiche in base ai moduli attivi
// =============================================================================

add_filter( 'woocommerce_account_menu_items', function ( $items ) {
	// Salva logout per aggiungerlo in fondo
	$logout = [];
	if ( isset( $items['customer-logout'] ) ) {
		$logout['customer-logout'] = $items['customer-logout'];
		unset( $items['customer-logout'] );
	}

	// Rimuovi dal menu WC le voci degli endpoint del plugin (se già presenti)
	foreach ( bncom_modules_registry() as $module ) {
		if ( ! empty( $module['endpoint'] ) ) {
			unset( $items[ $module['endpoint'] ] );
		}
	}
	// Rimuovi anche vecchi endpoint legacy
	unset( $items['bncom-products'], $items['bncom-wishlist'] );

	// Aggiungi solo i moduli attivi che hanno una voce di menu
	foreach ( bncom_modules_registry() as $id => $module ) {
		if ( ! empty( $module['menu_item'] ) && bncom_is_module_active( $id ) ) {
			$items[ $module['endpoint'] ] = $module['menu_label'];
		}
	}

	return array_merge( $items, $logout );
}, 20 );


// =============================================================================
// TITOLI PAGINA: endpoint → titolo
// =============================================================================

add_action( 'init', function () {
	foreach ( bncom_modules_registry() as $module ) {
		if ( ! empty( $module['endpoint'] ) ) {
			add_filter(
				'woocommerce_endpoint_' . $module['endpoint'] . '_title',
				fn() => $module['menu_label']
			);
		}
	}
} );
