// =========================================================================
// WIDGET TRACKING IN DASHBOARD
// Mostra l'ultimo ordine con numero tracking e stato 17track
// =========================================================================

function bncom_dashboard_tracking_widget( int $user_id ): void {
    // Trova l'ordine più recente con numero tracking
    $orders = wc_get_orders( [
        'customer_id' => $user_id,
        'status'      => [ 'processing', 'on-hold', 'wc-spedito', 'completed' ],
        'limit'       => 10,
        'orderby'     => 'date',
        'order'       => 'DESC',
        'return'      => 'objects',
    ] );

    $tracked_order  = null;
    $tracking_data  = null;
    $tracking_number = null;

    foreach ( $orders as $order ) {
        $tn = $order->get_meta( '_bncom_tracking_number' );
        if ( ! $tn ) continue;

        $cached = get_transient( 'bncom_track_' . md5( $tn ) );
        // Mostra solo ordini non ancora consegnati (status < 40)
        if ( $cached && ( $cached['status_code'] ?? 0 ) >= 40 ) continue;

        $tracked_order   = $order;
        $tracking_number = $tn;
        $tracking_data   = $cached;
        break;
    }

    if ( ! $tracked_order ) return;

    $status_labels = [
        0  => [ 'label' => 'In attesa di ritiro', 'icon' => 'fa-solid fa-hourglass-start',  'color' => '#6B7280' ],
        10 => [ 'label' => 'Tracking non trovato', 'icon' => 'fa-solid fa-question-circle', 'color' => '#6B7280' ],
        20 => [ 'label' => 'Ritirato dal corriere', 'icon' => 'fa-solid fa-box',            'color' => '#2563EB' ],
        30 => [ 'label' => 'In transito',           'icon' => 'fa-solid fa-truck-fast',     'color' => '#7C3AED' ],
        35 => [ 'label' => 'Tentativo fallito',     'icon' => 'fa-solid fa-triangle-exclamation', 'color' => '#D97706' ],
        40 => [ 'label' => 'Consegnato',            'icon' => 'fa-solid fa-circle-check',   'color' => '#16A34A' ],
    ];

    $status_code  = $tracking_data['status_code'] ?? 0;
    $st           = $status_labels[ $status_code ] ?? $status_labels[0];
    $last_event   = ! empty( $tracking_data['events'] ) ? $tracking_data['events'][0] : null;
    $order_url    = $tracked_order->get_view_order_url();
    ?>
    <div class="bncom-tracking-widget">
        <div class="bncom-tracking-widget__head">
            <span class="bncom-tracking-widget__label">
                <i class="fa-solid fa-truck-fast" aria-hidden="true"></i>
                Spedizione in corso
            </span>
            <a href="<?php echo esc_url( $order_url ); ?>" class="bncom-tracking-widget__link">
                Ordine #<?php echo esc_html( $tracked_order->get_order_number() ); ?> →
            </a>
        </div>
        <div class="bncom-tracking-widget__body">
            <div class="bncom-tracking-widget__status" style="color:<?php echo esc_attr( $st['color'] ); ?>">
                <i class="<?php echo esc_attr( $st['icon'] ); ?>" aria-hidden="true"></i>
                <?php echo esc_html( $st['label'] ); ?>
            </div>
            <?php if ( $last_event ) : ?>
            <p class="bncom-tracking-widget__event">
                <?php echo esc_html( $last_event['description'] ?? '' ); ?>
                <?php if ( $last_event['location'] ?? '' ) : ?>
                — <em><?php echo esc_html( $last_event['location'] ); ?></em>
                <?php endif; ?>
            </p>
            <p class="bncom-tracking-widget__date">
                <?php echo esc_html( date_i18n( 'd/m/Y H:i', $last_event['timestamp'] ?? time() ) ); ?>
            </p>
            <?php elseif ( $tracking_number ) : ?>
            <p class="bncom-tracking-widget__event">
                Numero tracking: <strong><?php echo esc_html( $tracking_number ); ?></strong>
                — In attesa di aggiornamenti dal corriere.
            </p>
            <?php endif; ?>
        </div>
    </div>
    <?php
}
