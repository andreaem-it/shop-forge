/**
 * Registra e carica i CSS del plugin.
 * Usa tre approcci in cascata per coprire WordPress standard, Elementor e Cart Block.
 *
 * Entrambi i CSS sono condizionali alla feature 'styles'.
 * Se 'styles' è disattivata il plugin non inietta nessun CSS sul sito.
 */
function bncom_enqueue_shop_css() {
    if ( ! class_exists( 'WooCommerce' ) ) {
        return;
    }
    // Carica solo se la feature "Stili personalizzati" è attiva
    if ( function_exists( 'bncom_is_module_active' ) && ! bncom_is_module_active( 'styles' ) ) {
        return;
    }
    if ( ! wp_style_is( 'bncom-woo-shop', 'enqueued' ) && ! wp_style_is( 'bncom-woo-shop', 'done' ) ) {
        wp_enqueue_style( 'bncom-woo-shop', BNCOM_SA_URL . 'assets/css/bncom-woo-shop.css', [], BNCOM_SA_VERSION );
    }
}

function bncom_enqueue_account_css() {
    if ( ! class_exists( 'WooCommerce' ) ) {
        return;
    }
    if ( function_exists( 'is_account_page' ) && is_account_page() ) {
        // FontAwesome: sempre caricato (necessario per le icone dei moduli attivi)
        wp_enqueue_script( 'fontawesome-kit', 'https://kit.fontawesome.com/051de31815.js', [], null, false );
        wp_script_add_data( 'fontawesome-kit', 'crossorigin', 'anonymous' );

        // CSS account: solo se la feature "Stili personalizzati" è attiva
        if ( ! function_exists( 'bncom_is_module_active' ) || bncom_is_module_active( 'styles' ) ) {
            wp_enqueue_style( 'bncom-woo-account', BNCOM_SA_URL . 'assets/css/bncom-woo-account.css', [], BNCOM_SA_VERSION );
        }
    }
}

// 1. Hook WordPress standard
add_action( 'wp_enqueue_scripts', 'bncom_enqueue_account_css', 20 );
add_action( 'wp_enqueue_scripts', 'bncom_enqueue_shop_css', 20 );

// 2. Hook Elementor — si attiva quando Elementor gestisce il rendering della pagina
add_action( 'elementor/frontend/after_enqueue_styles', 'bncom_enqueue_shop_css' );

// 3. Fallback wp_head — stampa il tag direttamente se nessuno dei metodi precedenti ha funzionato
//    Solo se la feature 'styles' è attiva.
add_action( 'wp_head', function () {
    if ( ! class_exists( 'WooCommerce' ) ) {
        return;
    }
    if ( function_exists( 'bncom_is_module_active' ) && ! bncom_is_module_active( 'styles' ) ) {
        return;
    }
    if ( wp_style_is( 'bncom-woo-shop', 'done' ) || wp_style_is( 'bncom-woo-shop', 'enqueued' ) ) {
        return;
    }
    $url = esc_url( BNCOM_SA_URL . 'assets/css/bncom-woo-shop.css?v=' . BNCOM_SA_VERSION );
    echo '<link rel="stylesheet" id="bncom-woo-shop-fallback-css" href="' . $url . '" media="all">' . "\n";
}, 999 );

// 4. Fix larghezza uniforme — iniettato a priorità 999 (DOPO il CSS di Elementor)
//    così le CSS custom properties sovrascrivono quelle di Elementor.
add_action( 'wp_head', function () {
    if ( ! is_account_page() ) {
        return;
    }
    ?>
    <style id="bncom-account-width-fix">
    /* Forza il widget Elementor a occupare tutta la larghezza disponibile
       su tutte le pagine account, non solo la bacheca. */
    .woocommerce-account .e-con-inner > *:has(.woocommerce-MyAccount-navigation) {
        --flex-grow: 1;
        --flex-shrink: 1;
        --flex-basis: 0%;
        min-width: 0;
    }
    .woocommerce-account .e-con-inner > *:has(.woocommerce-MyAccount-navigation) > .elementor-widget-container {
        width: 100%;
    }
    .woocommerce-account .woocommerce {
        width: 100%;
    }
    </style>
    <?php
}, 999 );

// 5. JS fallback — imposta la larghezza via stile inline dopo che tutto il CSS
//    (incluso Elementor) è stato caricato. Funziona anche se il hook wp_head
//    sopra non è ancora attivo per via dell'opcache.
add_action( 'wp_footer', function () {
    if ( ! is_account_page() ) {
        return;
    }
    ?>
    <script id="bncom-width-fix-js">
    (function() {
        function bncomFixWidth() {
            var widget = document.querySelector(
                '.woocommerce-account .e-con-inner > *:has(.woocommerce-MyAccount-navigation)'
            );
            if ( ! widget ) return;
            widget.style.setProperty('flex', '1 1 0%', 'important');
            widget.style.setProperty('min-width', '0', 'important');
            var wc = widget.querySelector('.elementor-widget-container');
            if ( wc ) wc.style.width = '100%';
        }
        if ( document.readyState === 'loading' ) {
            document.addEventListener('DOMContentLoaded', bncomFixWidth);
        } else {
            bncomFixWidth();
        }
    })();
    </script>
    <?php
}, 999 );


// =========================================================================
// MENU LATERALE ACCOUNT
// Ordine voci native WC — i moduli custom vengono aggiunti da bncom-modules.php
// =========================================================================

add_filter( 'woocommerce_account_menu_items', function ( $items ) {
    $logout = [];
    if ( isset( $items['customer-logout'] ) ) {
        $logout['customer-logout'] = $items['customer-logout'];
        unset( $items['customer-logout'] );
    }

    $wc_native = [ 'dashboard', 'orders', 'downloads', 'edit-address', 'edit-account', 'payment-methods' ];
    $menu = [];
    foreach ( $wc_native as $key ) {
        if ( isset( $items[ $key ] ) ) {
            $menu[ $key ] = $items[ $key ];
        }
    }

    // I moduli custom vengono inseriti da bncom-modules.php a priority 20
    // Qui restituiamo solo le voci native + logout (il merge avviene dopo)
    return array_merge( $menu, $logout );
}, 10 );


// =========================================================================
// RIORDINA RAPIDO — aggiunge azione "Riordina" nella lista ordini
// =========================================================================

add_filter( 'woocommerce_my_account_my_orders_actions', function ( array $actions, WC_Order $order ) {
    // Mostra "Riordina" solo se l'ordine è completato o annullato
    if ( in_array( $order->get_status(), [ 'completed', 'cancelled' ], true ) ) {
        $cart_url = wc_get_cart_url();
        $actions['reorder'] = [
            'url'  => add_query_arg( [
                'order_again'         => $order->get_id(),
                '_wpnonce'            => wp_create_nonce( 'woocommerce-order_again' ),
            ], $cart_url ),
            'name' => '<i class="fa-solid fa-rotate-right" aria-hidden="true"></i> Riordina',
        ];
    }
    return $actions;
}, 10, 2 );


// =========================================================================
// COLONNE TABELLA ORDINI
// Condizionale alla feature 'styles' — senza CSS custom le colonne WC native
// sono più adatte perché vengono stilizzate dal tema.
// =========================================================================

add_filter( 'woocommerce_account_orders_columns', function ( $columns ) {
    if ( function_exists( 'bncom_is_module_active' ) && ! bncom_is_module_active( 'styles' ) ) {
        return $columns; // usa le colonne WooCommerce predefinite
    }
    return [
        'order-number'  => 'Ordine',
        'order-date'    => 'Data',
        'order-status'  => 'Stato',
        'order-total'   => 'Totale',
        'order-actions' => 'Azioni',
    ];
}, 20 );


// =========================================================================
// STATUS BADGE nella tabella ordini
// WooCommerce 7+ emette testo puro — questo hook lo wrappa in mark.order-status
// Condizionale a 'styles': senza CSS il badge non è stilizzato.
// =========================================================================

add_action( 'woocommerce_my_account_my_orders_column_order-status', function ( $order ) {
    if ( function_exists( 'bncom_is_module_active' ) && ! bncom_is_module_active( 'styles' ) ) {
        // Fallback: output WC nativo
        echo esc_html( wc_get_order_status_name( $order->get_status() ) );
        return;
    }
    $status = $order->get_status();
    $label  = wc_get_order_status_name( $status );
    printf(
        '<mark class="order-status status-%s"><span>%s</span></mark>',
        esc_attr( sanitize_html_class( $status ) ),
        esc_html( $label )
    );
} );


