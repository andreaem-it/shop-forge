		var orderNum = <?php echo json_encode( '#' . $order_number ); ?>;
		var orderDate = <?php echo json_encode( $order_date ); ?>;
		var storeName = <?php echo json_encode( get_bloginfo('name') ); ?>;

		function open()  {
			backdrop.removeAttribute('aria-hidden');
			backdrop.classList.add('is-open');
			document.body.style.overflow = 'hidden';
		}
		function close() {
			backdrop.setAttribute('aria-hidden', 'true');
			backdrop.classList.remove('is-open');
			document.body.style.overflow = '';
		}

		openBtn?.addEventListener('click', open);
		closeBtn?.addEventListener('click', close);
		closeOk?.addEventListener('click', function() { close(); location.reload(); });
		backdrop?.addEventListener('click', function(e) { if (e.target === backdrop) close(); });
