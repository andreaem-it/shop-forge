		// ---- Step 1 → Step 2 ----
		nextBtn?.addEventListener('click', function() {
			err1.style.display = 'none';

			var checked  = Array.from(document.querySelectorAll('.shopforge-ret-prod:checked')).map(function(el){ return el.value; });
