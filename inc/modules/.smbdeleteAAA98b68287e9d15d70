add_action( 'wp_ajax_shopforge_submit_return', 'shopforge_submit_return_handler' );

function shopforge_submit_return_handler(): void {
	$order_id = absint( $_POST['order_id'] ?? 0 );

	if ( ! wp_verify_nonce( $_POST['nonce'] ?? '', 'shopforge_return_' . $order_id ) ) {
		wp_send_json_error( 'Sessione scaduta. Ricarica la pagina e riprova.' );
	}

	$order = wc_get_order( $order_id );
	if ( ! $order ) wp_send_json_error( 'Ordine non trovato.' );

	$user_id = get_current_user_id();
	if ( ! $user_id || (int) $order->get_customer_id() !== $user_id ) {
		wp_send_json_error( 'Accesso non autorizzato.' );
	}

	if ( ! shopforge_is_within_recesso_window( $order ) ) {
		wp_send_json_error( 'Il termine di 14 giorni per esercitare il recesso è scaduto.' );
	}

	if ( shopforge_has_active_return( $order ) ) {
		wp_send_json_error( 'Esiste già una richiesta di recesso per questo ordine.' );
	}

	$products    = array_map( 'sanitize_text_field', (array) ( $_POST['products'] ?? [] ) );
	$reason      = sanitize_text_field( $_POST['reason'] ?? '' );
	$refund      = sanitize_text_field( $_POST['refund'] ?? '' );
	$notes       = sanitize_textarea_field( $_POST['notes'] ?? '' );
	$declaration = sanitize_textarea_field( $_POST['declaration'] ?? '' );
	$products    = array_filter( $products );

	if ( ! $reason || empty( $products ) ) {
		wp_send_json_error( 'Dati mancanti o non validi.' );
	}

	$ref = 'REC-' . strtoupper( substr( md5( $order_id . time() ), 0, 8 ) );
	$now = current_time( 'mysql' );

	// 1. Salva nel meta ordine
	$returns   = $order->get_meta( '_shopforge_returns' ) ?: [];
	$returns[] = [
		'ref'         => $ref,
		'date'        => $now,
		'products'    => $products,
		'reason'      => $reason,
		'refund'      => $refund,
		'notes'       => $notes,
		'declaration' => $declaration,
		'status'      => 'pending',
	];
	$order->update_meta_data( '_shopforge_returns', $returns );
	$order->save();

	$customer_name  = $order->get_billing_first_name() . ' ' . $order->get_billing_last_name();
	$customer_email = $order->get_billing_email();
	$order_number   = $order->get_order_number();
	$site_name      = get_bloginfo( 'name' );
	$admin_email    = get_option( 'admin_email' );
	$date_str       = date_i18n( 'd/m/Y \a\l\l\e H:i', strtotime( $now ) );
	$products_str   = implode( "\n", array_map( fn( $p ) => '  • ' . $p, $products ) );

	// 2. Email admin
	wp_mail(
		$admin_email,
		sprintf( '[%s] Richiesta di recesso — Ordine #%s — Rif. %s', $site_name, $order_number, $ref ),
		sprintf(
			"Nuova richiesta di recesso ricevuta.\n\n" .
			"Riferimento: %s\n" .
			"Cliente: %s (%s)\n" .
			"Ordine: #%s\n" .
			"Data trasmissione: %s\n\n" .
			"Prodotti:\n%s\n\n" .
			"Motivo: %s\n" .
			"Rimborso preferito: %s\n" .
			( $notes ? "Note: %s\n\n" : "\n" ) .
			"--- DICHIARAZIONE DI RECESSO ---\n%s\n---\n\n" .
			"Gestisci l'ordine: %s",
			$ref,
			$customer_name, $customer_email,
			$order_number,
			$date_str,
			$products_str,
			$reason,
			$refund,
			$notes ? $notes . "\n\n" : '',
			$declaration,
			admin_url( 'post.php?post=' . $order_id . '&action=edit' )
		),
		[
			'Content-Type: text/plain; charset=UTF-8',
			'Reply-To: ' . $customer_name . ' <' . $customer_email . '>',
		]
	);

	// 3. Ricevuta automatica al cliente (obbligatoria per art. 54-bis)
	wp_mail(
		$customer_email,
		sprintf( '[%s] Ricevuta di recesso — Ordine #%s — Rif. %s', $site_name, $order_number, $ref ),
		sprintf(
			"Gentile %s,\n\n" .
			"Confermiamo la ricezione della tua dichiarazione di recesso.\n\n" .
			"Riferimento: %s\n" .
			"Data e ora di trasmissione: %s\n\n" .
			"=== DICHIARAZIONE DI RECESSO ===\n\n%s\n\n================================\n\n" .
			"Elaboreremo la tua richiesta e ti contatteremo entro i termini di legge.\n\n" .
			"Grazie,\n%s",
			$order->get_billing_first_name(),
			$ref,
			$date_str,
			$declaration,
			$site_name
		),
		[ 'Content-Type: text/plain; charset=UTF-8' ]
	);

	wp_send_json_success( [
		'ref'   => $ref,
		'email' => $customer_email,
	] );
}


