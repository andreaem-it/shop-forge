	<script>
	(function () {
		'use strict';
		var ajaxUrl = '<?php echo esc_url( admin_url('admin-ajax.php') ); ?>';
		var nonce   = '<?php echo esc_js( $nonce ); ?>';

		document.getElementById('bncom-quote-toggle')?.addEventListener('click', function () {
			var form = document.getElementById('bncom-quote-form');
			var icon = this.querySelector('i');
			var show = form.style.display === 'none';
			form.style.display = show ? 'block' : 'none';
			icon.className = show ? 'fa-solid fa-minus' : 'fa-solid fa-plus';
		});

		document.getElementById('bncom-quote-add-row')?.addEventListener('click', function () {
			var rows = document.getElementById('bncom-quote-rows');
			var tpl  = rows.querySelector('.bncom-quote-row-input').cloneNode(true);
			tpl.querySelector('.bncom-qrow-name').value = '';
			tpl.querySelector('.bncom-qrow-qty').value  = '1';
			rows.appendChild(tpl);
			tpl.querySelector('.bncom-qrow-name').focus();
		});

		document.getElementById('bncom-quote-rows')?.addEventListener('click', function (e) {
			var btn = e.target.closest('.bncom-qrow-remove');
			if ( ! btn ) return;
			var rows = this.querySelectorAll('.bncom-quote-row-input');
			if (rows.length > 1) btn.closest('.bncom-quote-row-input').remove();
		});

		document.getElementById('bncom-quote-form')?.addEventListener('submit', function (e) {
			e.preventDefault();
			var err    = document.getElementById('bncom-quote-error');
			var label  = document.getElementById('bncom-quote-label');
			var spin   = document.getElementById('bncom-quote-spinner');
			var submit = document.getElementById('bncom-quote-submit');
			err.style.display = 'none';

			var items = [];
			document.querySelectorAll('.bncom-quote-row-input').forEach(function (row) {
				var name = row.querySelector('.bncom-qrow-name').value.trim();
				var qty  = parseInt(row.querySelector('.bncom-qrow-qty').value) || 1;
				if (name) items.push({ name: name, qty: qty });
			});

			if ( ! items.length) { err.textContent = 'Inserisci almeno un prodotto.'; err.style.display = 'block'; return; }

			label.textContent = 'Invio in corso…';
			spin.style.display = 'inline-block';
			submit.disabled = true;

			var params = new URLSearchParams({ action: 'bncom_submit_quote', nonce: nonce, notes: document.getElementById('bncom-quote-notes').value.trim() });
			items.forEach(function (it, i) {
				params.append('items[' + i + '][name]', it.name);
				params.append('items[' + i + '][qty]',  it.qty);
			});

			fetch(ajaxUrl, { method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'}, body: params.toString() })
			.then(function (r) { return r.json(); })
			.then(function (d) {
				if (d.success) {
					document.getElementById('bncom-quote-success').style.display = 'block';
					document.getElementById('bncom-quote-success-text').textContent = 'Rif. ' + d.data.ref + ' — riceverai conferma a ' + d.data.email;
					submit.style.display = 'none';
				} else {
					err.textContent = d.data || 'Errore. Riprova.';
					err.style.display = 'block';
					label.textContent = 'Invia richiesta';
					spin.style.display = 'none';
					submit.disabled = false;
				}
			});
		});
	})();
