add_action( 'wp_ajax_bncom_submit_quote', 'bncom_submit_quote_handler' );

function bncom_submit_quote_handler(): void {
	$user_id = get_current_user_id();
	if ( ! $user_id ) wp_send_json_error( 'Accesso non autorizzato.' );

	if ( ! wp_verify_nonce( $_POST['nonce'] ?? '', 'bncom_quote_' . $user_id ) ) {
		wp_send_json_error( 'Sessione scaduta. Ricarica e riprova.' );
	}

	$items = [];
	foreach ( (array) ( $_POST['items'] ?? [] ) as $item ) {
		$name = sanitize_text_field( $item['name'] ?? '' );
		$qty  = absint( $item['qty'] ?? 1 );
		if ( $name ) $items[] = [ 'name' => $name, 'qty' => max( 1, $qty ) ];
	}
	if ( empty( $items ) ) wp_send_json_error( 'Inserisci almeno un prodotto.' );

	$notes = sanitize_textarea_field( $_POST['notes'] ?? '' );
	$ref   = 'PRV-' . strtoupper( substr( md5( $user_id . time() ), 0, 8 ) );
	$now   = current_time( 'mysql' );

	$quotes   = get_user_meta( $user_id, '_bncom_quotes', true ) ?: [];
	$quotes[] = [ 'ref' => $ref, 'date' => $now, 'items' => $items, 'notes' => $notes, 'status' => 'pending', 'reply' => '' ];
	update_user_meta( $user_id, '_bncom_quotes', $quotes );

	$user           = get_userdata( $user_id );
	$customer_email = $user->user_email;
	$customer_name  = $user->display_name;
	$site_name      = get_bloginfo( 'name' );
	$date_str       = date_i18n( 'd/m/Y \a\l\l\e H:i', strtotime( $now ) );
	$items_str      = implode( "\n", array_map( fn( $i ) => '  • ' . $i['qty'] . '× ' . $i['name'], $items ) );

	wp_mail(
		get_option( 'admin_email' ),
		sprintf( '[%s] Nuova richiesta preventivo — Rif. %s', $site_name, $ref ),
		sprintf( "Cliente: %s (%s)\nRif: %s\nData: %s\n\nProdotti:\n%s\n\n%s", $customer_name, $customer_email, $ref, $date_str, $items_str, $notes ? "Note: $notes" : '' ),
		[ 'Content-Type: text/plain; charset=UTF-8', 'Reply-To: ' . $customer_name . ' <' . $customer_email . '>' ]
	);

	wp_mail(
		$customer_email,
		sprintf( '[%s] Richiesta preventivo ricevuta — Rif. %s', $site_name, $ref ),
		sprintf( "Gentile %s,\n\nAbbiamo ricevuto la tua richiesta di preventivo (rif. %s).\n\nProdotti:\n%s\n\n%s\nTi risponderemo al più presto.\n\nGrazie,\n%s", $customer_name, $ref, $items_str, $notes ? "Note: $notes\n\n" : '', $site_name ),
		[ 'Content-Type: text/plain; charset=UTF-8' ]
	);

	do_action( 'bncom_notification', $user_id, 'quote_received', [
		'text' => 'La tua richiesta di preventivo ' . $ref . ' è stata ricevuta.',
		'url'  => wc_get_account_endpoint_url( 'bncom-quotes' ),
	] );

	wp_send_json_success( [ 'ref' => $ref, 'email' => $customer_email ] );
}


