<?php
/**
 * My Account navigation — BnCom override con icone FontAwesome
 *
 * Ogni voce mostra un'icona mappata in bncom_nav_icons().
 * Gli endpoint di plugin di terze parti che non sono in mappa
 * ricevono l'icona fallback (chevron-right) in modo che il layout
 * sia sempre uniforme.
 *
 * Sovrascrive: woocommerce/templates/myaccount/navigation.php
 *
 * @package BnComShopAccount
 */

defined( 'ABSPATH' ) || exit;

$icons    = function_exists( 'bncom_nav_icons' )        ? bncom_nav_icons()        : [];
$fallback = function_exists( 'bncom_nav_icon_fallback' ) ? bncom_nav_icon_fallback() : 'fa-solid fa-chevron-right';

do_action( 'woocommerce_before_account_navigation' );
?>
<nav class="woocommerce-MyAccount-navigation" aria-label="<?php esc_attr_e( 'Account pages', 'woocommerce' ); ?>">
    <ul>
        <?php foreach ( wc_get_account_menu_items() as $endpoint => $label ) :
            $icon = $icons[ $endpoint ] ?? $fallback;
        ?>
            <li class="<?php echo esc_attr( wc_get_account_menu_item_classes( $endpoint ) ); ?>">
                <a href="<?php echo esc_url( wc_get_account_endpoint_url( $endpoint ) ); ?>">
                    <i class="<?php echo esc_attr( $icon ); ?>" aria-hidden="true"></i>
                    <span><?php echo esc_html( $label ); ?></span>
                </a>
            </li>
        <?php endforeach; ?>
    </ul>
</nav>
<?php

do_action( 'woocommerce_after_account_navigation' );
